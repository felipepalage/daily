# Copie este arquivo para ".env" e ajuste os valores antes de rodar em produção.

# Conexão com o SQL Server. Formato:
# sqlserver://HOST:PORTA;database=BANCO;user=USUARIO;password=SENHA;encrypt=true;trustServerCertificate=true
# As tabelas do Daily ficam isoladas no schema "daily".
DATABASE_URL="sqlserver://localhost:1433;database=zivote;user=SEU_USUARIO;password=SUA_SENHA;encrypt=true;trustServerCertificate=true"

# Chave usada para assinar a sessão de login. Gere uma nova e única para
# produção, por exemplo com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=""

# URL pública do app, usada para montar o link de "esqueci minha senha" e o
# link de check-in nos e-mails de lembrete diário. Se não definida, o app
# tenta descobrir pela própria requisição. Comece com "https://" assim que
# tiver domínio/SSL configurado — isso também é o que ativa o cookie de
# sessão seguro (veja o comentário em src/lib/auth.ts).
APP_URL=""

# SMTP para envio de e-mails (recuperação de senha e lembretes de check-in).
# Sem essas variáveis, os e-mails só são impressos no log do servidor (modo dev).
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM=""

# Segredo para autorizar a chamada do endpoint de lembrete diário por e-mail
# (POST /api/cron/reminder com header "Authorization: Bearer <CRON_SECRET>").
# Gere com o mesmo comando sugerido para AUTH_SECRET.
CRON_SECRET=""
