// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model AppSetting {
  key   String @id
  value String
}

model ScrumMaster {
  id                   String               @id @default(cuid())
  name                 String
  email                String               @unique
  passwordHash         String
  createdAt            DateTime             @default(now())
  questionDoingLabel   String               @default("O que está fazendo?")
  questionBlockedLabel String               @default("O que está travado?")
  questionImproveLabel String               @default("O que pode melhorar?")
  teams                Team[]
  resetTokens          PasswordResetToken[]
}

model Team {
  id            String      @id @default(cuid())
  name          String
  createdAt     DateTime    @default(now())
  scrumMasterId String
  scrumMaster   ScrumMaster @relation(fields: [scrumMasterId], references: [id], onDelete: Cascade)
  developers    Developer[]
}

model Developer {
  id          String       @id @default(cuid())
  name        String
  role        String?
  email       String?
  publicToken String       @unique @default(cuid())
  createdAt   DateTime     @default(now())
  teamId      String
  team        Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  entries     DailyEntry[]
}

model DailyEntry {
  id          String    @id @default(cuid())
  date        DateTime
  doing       String
  blocked     String
  improve     String
  mood        String?
  scrumNote   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  developerId String
  developer   Developer @relation(fields: [developerId], references: [id], onDelete: Cascade)

  @@unique([developerId, date])
  @@index([date])
}

model PasswordResetToken {
  id            String      @id @default(cuid())
  tokenHash     String      @unique
  expiresAt     DateTime
  createdAt     DateTime    @default(now())
  scrumMasterId String
  scrumMaster   ScrumMaster @relation(fields: [scrumMasterId], references: [id], onDelete: Cascade)
}
