// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlserver"
  schemas  = ["daily"]
}

model AppSetting {
  key   String @id
  value String

  @@schema("daily")
}

model ScrumMaster {
  id                   String               @id @default(cuid())
  name                 String
  email                String               @unique
  passwordHash         String
  createdAt            DateTime             @default(now())
  questionDoingLabel   String               @default("O que está fazendo?")
  questionBlockedLabel String               @default("O que está travado?")
  questionImproveLabel String               @default("O que pode melhorar?")
  redmineUrl           String?
  redmineApiKey        String?
  teams                Team[]
  resetTokens          PasswordResetToken[]

  @@schema("daily")
}

model Team {
  id            String      @id @default(cuid())
  name          String
  createdAt     DateTime    @default(now())
  scrumMasterId String
  scrumMaster   ScrumMaster @relation(fields: [scrumMasterId], references: [id], onDelete: Cascade)
  developers    Developer[]

  @@schema("daily")
}

model Developer {
  id          String       @id @default(cuid())
  name        String
  role        String?
  email       String?
  publicToken String       @unique @default(cuid())
  createdAt   DateTime     @default(now())
  teamId      String
  team        Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  entries     DailyEntry[]

  @@schema("daily")
}

model DailyEntry {
  id            String    @id @default(cuid())
  date          DateTime
  doing         String    @db.NVarChar(Max)
  blocked       String    @db.NVarChar(Max)
  improve       String    @db.NVarChar(Max)
  mood          String?
  scrumNote     String?   @db.NVarChar(Max)
  featureNumber String?
  blockerNumber String?
  epicNumber    String?
  taskNumber    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  developerId   String
  developer     Developer @relation(fields: [developerId], references: [id], onDelete: Cascade)

  @@unique([developerId, date])
  @@index([date])
  @@schema("daily")
}

model PasswordResetToken {
  id            String      @id @default(cuid())
  tokenHash     String      @unique
  expiresAt     DateTime
  createdAt     DateTime    @default(now())
  scrumMasterId String
  scrumMaster   ScrumMaster @relation(fields: [scrumMasterId], references: [id], onDelete: Cascade)

  @@schema("daily")
}
