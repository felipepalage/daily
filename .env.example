# Copie este arquivo para ".env" e ajuste os valores antes de rodar.

# URL do backend .NET Daily.Api. Em produção, aponte para o servidor real.
DAILY_API_URL="http://localhost:5080"

# Opcional: chave para autorizar o cron de lembretes por e-mail
# (se o backend não tiver o cron integrado, mantido para compatibilidade).
CRON_SECRET=""

# SMTP para envio de e-mails (recuperação de senha e lembretes de check-in).
# Sem essas variáveis, os e-mails são apenas logados (modo dev).
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM=""

# URL pública do app, usada para montar links de "esqueci minha senha".
# Se não definida, o app tenta descobrir pela própria requisição.
APP_URL=""